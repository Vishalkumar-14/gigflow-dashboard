{
  "compilerOptions": {
    "rootDir": "./src",

   "module": "Node16",
   "moduleResolution": "node16",

    "target": "esnext",

    "types": ["node"],

    "sourceMap": true,

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "verbatimModuleSyntax": false
  }
}